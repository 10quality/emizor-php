{
    "name": "10quality/emizor-php-sdk",
    "description": "PHP SDK for the Emizor 5 REST API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Emizor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emizor\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": [
            "/.agents",
            "/.github",
            "/tests",
            "/prompt.md",
            "/phpunit.xml",
            "/phpstan.neon",
            "/.env.example",
            "/.gitignore"
        ]
    },
    "scripts": {
        "analyse": "phpstan analyse --configuration phpstan.neon",
        "test": "phpunit --configuration phpunit.xml",
        "test:coverage": "@php -d xdebug.mode=coverage vendor/bin/phpunit --configuration phpunit.xml --coverage-text"
    }
}
